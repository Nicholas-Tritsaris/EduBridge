{
  "name": "edubridge-linux",
  "version": "1.0.0",
  "description": "EduBridge - Linux Desktop Application",
  "main": "src/main.js",
  "homepage": "./",
  "homepage-electron": "file://%PUBLIC_URL%/index.html",
  "homepage-web": "http://localhost:3000",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "concurrently 'npm run start' 'wait-on http://localhost:3000 && electron .'",
    "dist": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "concurrently": "^7.0.0",
    "electron": "^latest",
    "electron-builder": "^latest",
    "react-scripts": "5.0.1",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.edubridge.linux",
    "productName": "EduBridge",
    "files": [
      "build/**/*",
      "src/main.js",
      "src/preload.js",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    },
    "directories": {
      "buildResources": "public"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
